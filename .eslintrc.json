{
  "root": true,
  "env": {
    "node": true,
    "es2024": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "rules": {
    "@typescript-eslint/no-unused-vars": "error"
  },
  "overrides": [
    {
      "files": ["**/*.js", "**/*.mjs", "**/*.cjs"],
      "parserOptions": {
        "sourceType": "module"
      }
    }
  ]
}
